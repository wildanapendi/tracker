# =============================================================================
# SkripsiTracker — Production Environment Configuration
# =============================================================================
# Salin file ini ke .env lalu sesuaikan nilainya:
#   cp .env.production.example .env
# JANGAN commit file .env ke version control!
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="SkripsiTracker"
APP_ENV=production
APP_KEY=                          # Jalankan: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com   # Ganti dengan domain produksi Anda

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # Gunakan 'error' di produksi; jangan 'debug'

# ---------------------------------------------------------------------------
# Database — MySQL (Recommended for Production)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=skripsi_tracker
DB_USERNAME=skripsi_user
DB_PASSWORD=                      # WAJIB diisi — gunakan password yang kuat

# Jika menggunakan SQLite (hanya untuk single-server atau testing):
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

# ---------------------------------------------------------------------------
# Session & Cache
# ---------------------------------------------------------------------------
SESSION_DRIVER=database           # Ganti ke 'redis' jika Redis tersedia
SESSION_LIFETIME=120
SESSION_ENCRYPT=true              # Aktifkan enkripsi session di produksi
SESSION_SECURE_COOKIE=true        # Cookie hanya dikirim via HTTPS
SESSION_PATH=/
SESSION_DOMAIN=your-domain.com    # Sesuaikan dengan domain Anda

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database         # Ganti ke 'redis' jika Redis tersedia

CACHE_STORE=database              # Ganti ke 'redis' jika Redis tersedia

# ---------------------------------------------------------------------------
# Redis (Opsional — untuk Queue, Cache, Session berkinerja tinggi)
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                   # Isi jika Redis dikonfigurasi dengan password
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp                  # Ganti sesuai provider: smtp, mailgun, ses
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io        # Ganti dengan SMTP provider produksi
MAIL_PORT=587
MAIL_USERNAME=                    # WAJIB diisi
MAIL_PASSWORD=                    # WAJIB diisi
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# File Storage (Opsional — untuk upload dokumen Milestone)
# ---------------------------------------------------------------------------
# Gunakan S3-compatible storage di produksi untuk skalabilitas
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=skripsi-tracker-bucket
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
